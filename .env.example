DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=aws_ecommerce
DB_PORT=3306

APP_NAME=ShopNest
APP_URL=http://localhost/aws-ecommerce
APP_ENV=development
APP_DEBUG=true

# AWS S3 (for production)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=shopnest-products
AWS_URL=https://shopnest-products.s3.ap-south-1.amazonaws.com

# AWS SNS (for order notifications)
AWS_SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:shopnest-orders

ADMIN_EMAIL=admin@shopnest.com

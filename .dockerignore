# ============================================================
#  .dockerignore — ShopNest
#  Keeps the Docker build context lean and secure
# ============================================================

# Git
.git
.gitignore
.gitattributes

# Docker files (already in image)
Dockerfile
docker-compose.yml
docker-compose*.yml
.dockerignore

# Environment secrets (injected at runtime)
.env
.env.*
!.env.example

# XAMPP / local dev artifacts
*.log
logs/

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Node (if any tooling exists)
node_modules/

# README and docs
README.md
CHANGELOG.md
*.md

# CI / CD
.github/
.gitlab-ci.yml
